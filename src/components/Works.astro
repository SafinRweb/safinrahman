---
// Works / Project Gallery section
interface Project {
  index: string;
  category: string;
  title: string;
  description: string;
  tags: string[];
  gradient: string;
  svgContent: string;
  even?: boolean;
}

const projects: Project[] = [
  {
    index: '01 / 04',
    category: 'SaaS',
    title: 'fls.tv<br/>Football Streaming Platform',
    description: 'A premium, modern web application designed to deliver an immersive and cinematic football tracking and streaming experience. Built with performance and aesthetics in mind, it provides real-time match data, chronological upcoming schedules, and a dedicated distraction-free viewing environment.',
    tags: ['Next.js 14', 'React 19', 'Framer Motion', 'Tailwind CSS v3', 'TypeScript', 'Vercel', 'Lucide React'],
    gradient: 'bg-gradient-to-br from-[#0d0d0d] via-[#181818] to-[#0a0a0a]',
    svgContent: `<rect x="20" y="20" width="70" height="70" stroke="rgba(255,255,255,.4)" stroke-width=".5"/><rect x="40" y="40" width="70" height="70" stroke="rgba(255,255,255,.18)" stroke-width=".5"/><rect x="60" y="60" width="70" height="70" stroke="rgba(255,255,255,.09)" stroke-width=".5"/><line x1="20" y1="90" x2="160" y2="90" stroke="rgba(255,255,255,.12)" stroke-width=".5"/><circle cx="110" cy="50" r="18" stroke="rgba(255,255,255,.32)" stroke-width=".5"/><circle cx="110" cy="50" r="7" fill="rgba(255,255,255,.1)"/>`,
  },
  {
    index: '02 / 04',
    category: 'Frontend & UI Design',
    title: 'spylt<br/>Animated Milk Drink Brand Website',
    description: 'Spylt is a fully animated and visually engaging website built for a fictional milk drink brand, showcasing their unique flavors with motion-rich transitions and smooth UI.',
    tags: ['React', 'Tailwind CSS', 'GSAP', 'Framer Motion'],
    gradient: 'bg-gradient-to-bl from-[#101010] via-[#1c1c1c] to-[#080808]',
    svgContent: `<path d="M20 70 Q60 20 100 70 Q140 120 180 70" stroke="rgba(255,255,255,.45)" stroke-width=".8" fill="none"/><path d="M20 70 Q60 40 100 70 Q140 100 180 70" stroke="rgba(255,255,255,.2)" stroke-width=".5" fill="none"/><path d="M20 70 Q60 55 100 70 Q140 85 180 70" stroke="rgba(255,255,255,.1)" stroke-width=".5" fill="none"/><circle cx="20" cy="70" r="4" fill="rgba(255,255,255,.5)"/><circle cx="100" cy="70" r="4" fill="rgba(255,255,255,.5)"/><circle cx="180" cy="70" r="4" fill="rgba(255,255,255,.5)"/>`,
    even: true,
  },
  {
    index: '03 / 04',
    category: 'Full Stack & SaaS',
    title: 'Escrims<br/>Esports Tournament Platform',
    description: 'A modern, full-featured esports tournament management platform built with React, TypeScript, and Firebase. Create tournaments, manage brackets, track standings, and share live streams — all in one place.',
    tags: ['React', 'TypeScript', 'Firebase', 'Tailwind CSS','Cloud Firestore','React Router','Vercel'],
    gradient: 'bg-gradient-to-tr from-[#0c0c0c] via-[#171717] to-[#0e0e0e]',
    svgContent: `<polygon points="100,18 168,58 168,98 100,138 32,98 32,58" stroke="rgba(255,255,255,.4)" stroke-width=".6" fill="none"/><polygon points="100,34 152,64 152,94 100,124 48,94 48,64" stroke="rgba(255,255,255,.18)" stroke-width=".5" fill="none"/><polygon points="100,52 136,72 136,92 100,112 64,92 64,72" stroke="rgba(255,255,255,.09)" stroke-width=".5" fill="none"/><circle cx="100" cy="78" r="6" fill="rgba(255,255,255,.28)"/>`,
  },
  {
    index: '04 / 04',
    category: 'MERN Stack',
    title: 'Prescripto<br/>A online doctor appointment platform',
    description: 'Prescripto is a modern online doctor appointment platform designed to connect patients with healthcare professionals seamlessly. The goal is to provide a smooth and responsive user experience for booking and managing appointments.',
    tags: ['React', 'TypeScript', 'MongoDB', 'Express', 'Node.js', 'Tailwind CSS','Vercel'],
    gradient: 'bg-gradient-to-tl from-[#0f0f0f] via-[#1a1a1a] to-[#090909]',
    svgContent: `<line x1="30" y1="30" x2="170" y2="30" stroke="rgba(255,255,255,.35)" stroke-width=".5"/><line x1="30" y1="55" x2="130" y2="55" stroke="rgba(255,255,255,.2)" stroke-width=".5"/><line x1="30" y1="80" x2="150" y2="80" stroke="rgba(255,255,255,.25)" stroke-width=".5"/><line x1="30" y1="105" x2="100" y2="105" stroke="rgba(255,255,255,.15)" stroke-width=".5"/><rect x="30" y="25" width="5" height="5" fill="rgba(255,255,255,.5)"/><rect x="30" y="50" width="5" height="5" fill="rgba(255,255,255,.35)"/><rect x="30" y="75" width="5" height="5" fill="rgba(255,255,255,.4)"/><rect x="30" y="100" width="5" height="5" fill="rgba(255,255,255,.25)"/>`,
    even: true,
  },
];
---

<section id="works" class="section px-[clamp(20px,4vw,64px)] py-[clamp(80px,12vh,140px)] border-t border-white/[0.07]">
  <p class="s-label font-mono text-[11px] tracking-[0.32em] text-white/[0.26] uppercase flex items-center gap-3 mb-14">
    <span class="block w-7 h-px bg-white/[0.18]"></span>
    <span class="text-white/[0.18] mr-1.5">01</span> Selected Works
  </p>

  <div class="work-grid">
    {projects.map((project, idx) => (
      <article
        class:list={[
          'work-item grid border-b border-white/[0.07] py-[clamp(32px,5vw,64px)] overflow-hidden relative cursor-none reveal',
          project.even ? 'even' : '',
          idx === 0 ? 'border-t border-white/[0.07]' : '',
          idx > 0 ? `rd${idx}` : '',
        ]}
        data-delay={idx * 0.1}
      >
        <div class="work-thumb aspect-[16/10] overflow-hidden relative">
          <div class={`work-thumb-in w-full h-full flex items-center justify-center relative transition-transform duration-[800ms] ease-[cubic-bezier(0.22,1,0.36,1)] ${project.gradient}`}>
            <span class="w-idx absolute top-4 left-4 font-mono text-[10px] tracking-[0.2em] text-white/[0.28]">{project.index}</span>
            <svg class="thumb-art w-[58%] h-[58%] opacity-50" viewBox="0 0 200 140" fill="none">
              <Fragment set:html={project.svgContent} />
            </svg>
            <span class="w-view absolute bottom-4 right-4 font-mono text-[10px] tracking-[0.18em] uppercase flex items-center gap-2 text-transparent transition-colors duration-[400ms]" data-scramble="View Project">View Project</span>
          </div>
        </div>
        <div class="work-info px-[clamp(24px,4vw,56px)] flex flex-col justify-center">
          <p class="w-cat font-mono text-[11px] tracking-[0.28em] text-white/[0.28] uppercase mb-3.5">{project.category}</p>
          <h2 class="w-title font-display font-bold text-[clamp(32px,4.5vw,68px)] tracking-[-0.01em] leading-[0.9] text-white mb-[18px]">
            <Fragment set:html={project.title} />
          </h2>
          <p class="w-desc text-[13px] text-white/[0.36] leading-[1.85] max-w-[320px] mb-[26px]">{project.description}</p>
          <div class="w-tags flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <span class="w-tag font-mono text-[10px] tracking-[0.15em] text-white/[0.38] uppercase border border-white/[0.1] px-2.5 py-[5px] rounded-[1px] transition-all duration-300">{tag}</span>
            ))}
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .work-item {
    grid-template-columns: 1fr 1fr;
  }

  .work-item.even {
    direction: rtl;
  }

  .work-item.even > * {
    direction: ltr;
  }

  .work-item::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0);
    transition: background 0.6s ease;
  }

  .work-item:hover::before {
    background: rgba(255, 255, 255, 0.015);
  }

  .work-item:hover .work-thumb-in {
    transform: scale(1.04);
  }

  .work-item:hover .w-view {
    color: rgba(255, 255, 255, 0.65);
  }

  .work-item:hover .w-view::before {
    width: 22px;
  }

  .work-item:hover .w-tag {
    border-color: rgba(255, 255, 255, 0.22);
    color: rgba(255, 255, 255, 0.6);
  }

  .w-view::before {
    content: '';
    display: block;
    width: 0;
    height: 1px;
    background: #fff;
    transition: width 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Reveal animation */
  .reveal {
    opacity: 0;
    transform: translateY(34px);
    transition: opacity 0.85s ease, transform 1s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal.in {
    opacity: 1;
    transform: translateY(0);
  }

  .rd1 { transition-delay: 0.1s; }
  .rd2 { transition-delay: 0.2s; }
  .rd3 { transition-delay: 0.3s; }

  @media (max-width: 900px) {
    .work-item {
      grid-template-columns: 1fr;
    }
    .work-item.even {
      direction: ltr;
    }
    .work-info {
      padding: 28px 0 0;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // ScrollTrigger reveals for work items
  document.querySelectorAll<HTMLElement>('.work-item.reveal').forEach((el) => {
    ScrollTrigger.create({
      trigger: el,
      start: 'top 90%',
      once: true,
      onEnter: () => {
        el.classList.add('in');

        // Scramble data-scramble children on reveal
        el.querySelectorAll<HTMLElement>('[data-scramble]').forEach((child) => {
          const orig = child.getAttribute('data-scramble') || '';
          const GLYPHS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*<>/\\|~';
          const totalFrames = Math.ceil(700 / 48);
          let it = 0;
          const timer = setInterval(() => {
            child.textContent = orig
              .split('')
              .map((c, i) => {
                if (c === ' ') return ' ';
                if (i < Math.floor(it / (totalFrames / orig.length))) return c;
                return GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
              })
              .join('');
            if (++it >= totalFrames) {
              child.textContent = orig;
              clearInterval(timer);
            }
          }, 48);
        });
      },
    });
  });
</script>
